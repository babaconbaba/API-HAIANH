PORT=3003
NODE_ENV=development

# Auth
AUTH_MODE=apikey
API_KEYS=misa-api-key-2026
JWT_SECRET=change-me-in-production

# Default SQL Connection
SQL_INSTANCE=.\\MISASME2026
SQL_DATABASE=MISASME2026SampleTT133
SQL_AUTH=windows
SQL_USERNAME=
SQL_PASSWORD=

# Remote SQL Server (uncomment to use)
# SQL_INSTANCE=192.168.1.100\\MISASME2026
# SQL_DATABASE=CompanyDB2026
# SQL_AUTH=sql
# SQL_USERNAME=sa
# SQL_PASSWORD=your_password_here

# Pool
SQL_POOL_MAX=50
SQL_POOL_MIN=0
SQL_POOL_IDLE_TIMEOUT=30000
SQL_REQUEST_TIMEOUT=30000

# Cluster (default = CPU cores)
# WORKERS=4

# Rate limit (requests per 15 min per IP)
# RATE_LIMIT_MAX=1000
